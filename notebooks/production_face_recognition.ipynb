  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 3: Core Components - Face Detection & Preprocessing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class FaceDetector:\n",
    "    \"\"\"\n",
    "    Production-grade face detector using MTCNN\n",
    "    \n",
    "    Features:\n",
    "    - Multi-scale detection\n",
    "    - Facial landmark detection (5 points)\n",
    "    - Face alignment\n",
    "    - Quality scoring\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, device=device):\n",
    "        self.device = device\n",
    "        self.mtcnn = MTCNN(\n",
    "            image_size=Config.IMAGE_SIZE,\n",
    "            margin=0,\n",
    "            min_face_size=Config.MIN_FACE_SIZE,\n",
    "            thresholds=Config.MTCNN_THRESHOLDS,\n",
    "            factor=0.709,\n",
    "            post_process=True,\n",
    "            device=self.device,\n",
    "            keep_all=True\n",
    "        )\n",
    "        print(f\"✅ MTCNN initialized on {device}\")\n",
    "    \n",
    "    def detect_faces(self, image: np.ndarray) -> Tuple[List, List, List]:\n",
    "        \"\"\"\n",
    "        Detect faces with bounding boxes, landmarks, and confidence\n",
    "        \n",
    "        Args:\n",
    "            image: RGB image (H, W, 3)\n",
    "            \n",
    "        Returns:\n",
    "            boxes: List of [x1, y1, x2, y2]\n",
    "            probs: Confidence scores\n",
    "            landmarks: 5-point facial landmarks\n",
    "        \"\"\"\n",
    "        boxes, probs, landmarks = self.mtcnn.detect(image, landmarks=True)\n",
    "        \n",
    "        if boxes is None:\n",
    "            return [], [], []\n",
    "        \n",
    "        return boxes.tolist(), probs.tolist(), landmarks.tolist()\n",
    "    \n",
    "    def extract_face(self, image: np.ndarray, return_prob=False):\n",
    "        \"\"\"\n",
    "        Extract and align face from image\n",
    "        \n",
    "        Returns:\n",
    "            face_tensor: Aligned face (3, 160, 160) or None\n",
    "            prob: Detection confidence (if return_prob=True)\n",
    "        \"\"\"\n",
    "        face = self.mtcnn(image, return_prob=return_prob)\n",
    "        return face\n",
    "    \n",
    "    def check_quality(self, image: np.ndarray) -> Dict[str, float]:\n",
    "        \"\"\"\n",
    "        Assess image quality for face recognition\n",
    "        \n",
    "        Checks:\n",
    "        - Blur (Laplacian variance)\n",
    "        - Brightness\n",
    "        - Contrast\n",
    "        \"\"\"\n",
    "        gray = cv2.cvtColor(image, cv2.COLOR_RGB2GRAY)\n",
    "        \n",
    "        # Blur detection\n",
    "        blur_score = cv2.Laplacian(gray, cv2.CV_64F).var()\n",
    "        \n",
    "        # Brightness\n",
    "        brightness = np.mean(gray)\n",
    "        \n",
    "        # Contrast\n",
    "        contrast = np.std(gray)\n",
    "        \n",
    "        return {\n",
    "            'blur_score': blur_score,\n",
    "            'brightness': brightness,\n",
    "            'contrast': contrast,\n",
    "            'is_blurry': blur_score < Config.MAX_BLUR_THRESHOLD,\n",
    "            'is_dark': brightness < Config.MIN_BRIGHTNESS,\n",
    "            'is_bright': brightness > Config.MAX_BRIGHTNESS\n",
    "        }\n",
    "\n",
    "# Initialize detector\n",
    "face_detector = FaceDetector(device=device)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 4: Embedding Extraction Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class FaceEmbedder:\n",
    "    \"\"\"\n",
    "    Face embedding extraction using pre-trained InceptionResnetV1\n",
    "    \n",
    "    Architecture:\n",
    "    - Input: 160x160x3 RGB face\n",
    "    - Output: 512-D L2-normalized embedding\n",
    "    - Pre-trained on VGGFace2 (3.3M images, 9K identities)\n",
    "    \n",
    "    Key Properties:\n",
    "    - Frozen weights (no training needed)\n",
    "    - Embeddings lie on unit hypersphere\n",
    "    - Cosine similarity = dot product\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, model_name='vggface2', device=device):\n",
    "        self.device = device\n",
    "        self.model = InceptionResnetV1(\n",
    "            pretrained=model_name,\n",
    "            classify=False,\n",
    "            device=self.device\n",
    "        ).eval()\n",
    "        \n",
    "        print(f\"✅ FaceNet model loaded: {model_name}\")\n",
    "        print(f\"   - Parameters: {sum(p.numel() for p in self.model.parameters()):,}\")\n",
    "        print(f\"   - Embedding dim: {Config.EMBEDDING_DIM}\")\n",
    "    \n",
    "    @torch.no_grad()\n",
    "    def extract_embedding(self, face_tensor: torch.Tensor) -> np.ndarray:\n",
    "        \"\"\"\n",
    "        Extract L2-normalized embedding from face tensor\n",
    "        \n",
    "        Args:\n",
    "            face_tensor: (3, 160, 160) or (B, 3, 160, 160)\n",
    "            \n",
    "        Returns:\n",
    "            embedding: (512,) or (B, 512) normalized vector\n",
    "        \"\"\"\n",
    "        if face_tensor is None:\n",
    "            return None\n",
    "        \n",
    "        # Add batch dimension if needed\n",
    "        if face_tensor.dim() == 3:\n",
    "            face_tensor = face_tensor.unsqueeze(0)\n",
    "        \n",
    "        face_tensor = face_tensor.to(self.device)\n",
    "        \n",
    "        # Extract embedding\n",
    "        embedding = self.model(face_tensor)\n",
    "        \n",
    "        # L2 normalize\n",
    "        embedding = torch.nn.functional.normalize(embedding, p=2, dim=1)\n",
    "        \n",
    "        return embedding.cpu().numpy()\n",
    "    \n",
    "    @torch.no_grad()\n",
    "    def extract_batch_embeddings(self, face_tensors: List[torch.Tensor]) -> np.ndarray:\n",
    "        \"\"\"\n",
    "        Extract embeddings for batch of faces\n",
    "        \n",
    "        Args:\n",
    "            face_tensors: List of (3, 160, 160) tensors\n",
    "            \n",
    "        Returns:\n",
    "            embeddings: (N, 512) array\n",
    "        \"\"\"\n",
    "        if not face_tensors:\n",
    "            return np.array([])\n",
    "        \n",
    "        # Stack into batch\n",
    "        batch = torch.stack(face_tensors).to(self.device)\n",
    "        \n",
    "        # Extract embeddings\n",
    "        embeddings = self.model(batch)\n",
    "        \n",
    "        # L2 normalize\n",
    "        embeddings = torch.nn.functional.normalize(embeddings, p=2, dim=1)\n",
    "        \n",
    "        return embeddings.cpu().numpy()\n",
    "\n",
    "# Initialize embedder\n",
    "face_embedder = FaceEmbedder(model_name=Config.EMBEDDING_MODEL, device=device)"
   ]
  }
 ],
 "nbformat": 4,
 "nbformat_minor": 4
}
