  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 2: Configuration & Hyperparameters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class Config:\n",
    "    \"\"\"Production system configuration\"\"\"\n",
    "    \n",
    "    # Paths\n",
    "    BASE_DIR = Path('../data')\n",
    "    DATASET_DIR = BASE_DIR / 'faces'\n",
    "    DB_DIR = BASE_DIR / 'database'\n",
    "    MODELS_DIR = Path('../models')\n",
    "    LOGS_DIR = Path('../logs')\n",
    "    \n",
    "    # Database files\n",
    "    VECTOR_DB_PATH = DB_DIR / 'face_vectors.index'\n",
    "    METADATA_DB_PATH = DB_DIR / 'metadata.db'\n",
    "    EMBEDDINGS_PATH = DB_DIR / 'embeddings.npy'\n",
    "    IDENTITIES_PATH = DB_DIR / 'identities.json'\n",
    "    \n",
    "    # Model settings\n",
    "    EMBEDDING_MODEL = 'vggface2'  # or 'casia-webface'\n",
    "    EMBEDDING_DIM = 512\n",
    "    IMAGE_SIZE = 160\n",
    "    \n",
    "    # Face detection\n",
    "    MTCNN_THRESHOLDS = [0.6, 0.7, 0.7]  # P-Net, R-Net, O-Net\n",
    "    MIN_FACE_SIZE = 40\n",
    "    \n",
    "    # Recognition thresholds\n",
    "    SIMILARITY_THRESHOLD = 0.5  # Cosine similarity\n",
    "    DISTANCE_THRESHOLD = 1.0    # Euclidean distance\n",
    "    CONFIDENCE_THRESHOLD = 0.6\n",
    "    \n",
    "    # Registration\n",
    "    MIN_IMAGES_PER_IDENTITY = 5\n",
    "    MAX_IMAGES_PER_IDENTITY = 50\n",
    "    \n",
    "    # Quality filters\n",
    "    MIN_FACE_CONFIDENCE = 0.9\n",
    "    MAX_BLUR_THRESHOLD = 100  # Laplacian variance\n",
    "    MIN_BRIGHTNESS = 50\n",
    "    MAX_BRIGHTNESS = 200\n",
    "    \n",
    "    # Training\n",
    "    TRAIN_SPLIT = 0.8\n",
    "    VAL_SPLIT = 0.2\n",
    "    RANDOM_SEED = 42\n",
    "    \n",
    "    # Performance\n",
    "    BATCH_SIZE = 32\n",
    "    NUM_WORKERS = 4\n",
    "    \n",
    "    @classmethod\n",
    "    def create_directories(cls):\n",
    "        \"\"\"Create all necessary directories\"\"\"\n",
    "        for dir_path in [cls.BASE_DIR, cls.DATASET_DIR, cls.DB_DIR, \n",
    "                         cls.MODELS_DIR, cls.LOGS_DIR]:\n",
    "            dir_path.mkdir(parents=True, exist_ok=True)\n",
    "        print(\"✅ Directories created\")\n",
    "\n",
    "# Initialize\n",
    "Config.create_directories()\n",
    "np.random.seed(Config.RANDOM_SEED)\n",
    "torch.manual_seed(Config.RANDOM_SEED)\n",
    "\n",
    "print(f\"\\n📁 Configuration:\")\n",
    "print(f\"  - Dataset: {Config.DATASET_DIR}\")\n",
    "print(f\"  - Database: {Config.DB_DIR}\")\n",
    "print(f\"  - Embedding dim: {Config.EMBEDDING_DIM}\")\n",
    "print(f\"  - Similarity threshold: {Config.SIMILARITY_THRESHOLD}\")"
   ]
  }
 ],
 "nbformat": 4,
