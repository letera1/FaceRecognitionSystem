    "print(f\"\\n📊 System Configuration:\")\n",
    "print(f\"  - Python: {sys.version.split()[0]}\")\n",
    "print(f\"  - NumPy: {np.__version__}\")\n",
    "print(f\"  - OpenCV: {cv2.__version__}\")\n",
    "print(f\"  - Device: {device}\")\n",
    "\n",
