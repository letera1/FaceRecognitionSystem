   "source": [
    "## 16. Real-Time Face Recognition Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def test_realtime_recognition():\n",
    "    \"\"\"\n",
    "    Test face recognition in real-time using webcam\n",
    "    Press ESC to stop\n",
    "    \"\"\"\n",
    "    if not os.path.exists(MODEL_PATH):\n",
    "        print(\"❌ Model not found! Please train the model first.\")\n",
    "        return\n",
    "    \n",
    "    # Load model\n",
    "    model_data = joblib.load(MODEL_PATH)\n",
    "    model = model_data['model']\n",
    "    label_encoder = model_data['label_encoder']\n",
    "    \n",
    "    print(\"Starting real-time recognition...\")\n",
    "    print(\"Press ESC to stop\")\n",
    "    \n",
    "    cap = cv2.VideoCapture(0)\n",
    "    \n",
    "    while True:\n",
    "        ret, frame = cap.read()\n",
    "        if not ret:\n",
    "            break\n",
    "        \n",
    "        # Convert to RGB\n",
    "        rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)\n",
    "        \n",
    "        # Detect faces\n",
    "        face_locations = face_recognition.face_locations(rgb_frame)\n",
    "        face_encodings = face_recognition.face_encodings(rgb_frame, face_locations)\n",
    "        \n",
    "        # Recognize each face\n",
    "        for (top, right, bottom, left), face_encoding in zip(face_locations, face_encodings):\n",
    "            # Predict\n",
    "            prediction = model.predict([face_encoding])[0]\n",
    "            confidence = np.max(model.predict_proba([face_encoding]))\n",
    "            name = label_encoder.inverse_transform([prediction])[0]\n",
    "            \n",
    "            # Draw rectangle\n",
    "            color = (0, 255, 0) if confidence > CONFIDENCE_THRESHOLD else (0, 0, 255)\n",
    "            cv2.rectangle(frame, (left, top), (right, bottom), color, 2)\n",
    "            \n",
    "            # Draw label\n",
    "            label = f\"{name} ({confidence:.2f})\"\n",
    "            cv2.rectangle(frame, (left, bottom - 35), (right, bottom), color, cv2.FILLED)\n",
    "            cv2.putText(frame, label, (left + 6, bottom - 6),\n",
    "                       cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255, 255, 255), 2)\n",
    "        \n",
    "        cv2.imshow('Face Recognition - Press ESC to stop', frame)\n",
    "        \n",
    "        if cv2.waitKey(1) == 27:  # ESC\n",
    "            break\n",
    "    \n",
    "    cap.release()\n",
    "    cv2.destroyAllWindows()\n",
    "    print(\"✅ Test completed\")\n",
    "\n",
    "# Uncomment to test:\n",
    "# test_realtime_recognition()"
   ]
  },
